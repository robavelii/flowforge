generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Baseline system metadata (M0)
model SystemMetadata {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(255)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_metadata")
}

enum WorkspaceStatus {
  active
  suspended
}

enum MemberStatus {
  active
  suspended
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum AbacEffect {
  allow
  deny
}

enum ApiKeyStatus {
  active
  revoked
  expired
}

enum WorkflowStatus {
  draft
  published
  unpublished
}

enum WorkflowNodeType {
  trigger
  action
  condition
  delay
  loop
}

enum ExecutionStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum ExecutionTriggerType {
  manual
  api
  schedule
  webhook
  replay
}

enum ExecutionStepStatus {
  pending
  running
  completed
  failed
  skipped
  cancelled
}

enum ScheduleStatus {
  active
  paused
  deleted
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @db.VarChar(320)
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  name            String    @db.VarChar(255)
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions           Session[]
  refreshTokens      RefreshToken[]
  oauthAccounts      OAuthAccount[]
  ownedOrganizations Organization[]     @relation("OrganizationOwner")
  memberships        WorkspaceMember[]
  invitationsSent    Invitation[]       @relation("InvitationInviter")
  apiKeysCreated     ApiKey[]           @relation("ApiKeyCreator")
  auditLogs          AuditLog[]         @relation("AuditLogActor")
  timelineEvents     TimelineEvent[]    @relation("TimelineEventActor")
  workflowsCreated   Workflow[]         @relation("WorkflowCreator")
  workflowDraftsSaved WorkflowDraft[]   @relation("WorkflowDraftSaver")
  workflowVersionsPublished WorkflowVersion[] @relation("WorkflowVersionPublisher")
  executionsStarted  WorkflowExecution[] @relation("ExecutionStarter")

  @@unique([email])
  @@index([createdAt])
  @@map("users")
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  ipAddress    String?   @map("ip_address") @db.VarChar(64)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  familyId  String    @map("family_id") @db.Uuid
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([sessionId])
  @@map("refresh_tokens")
}

model OAuthAccount {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String    @db.VarChar(32)
  providerUserId  String    @map("provider_user_id") @db.VarChar(255)
  accessTokenEnc  String?   @map("access_token_enc") @db.Text
  refreshTokenEnc String?   @map("refresh_token_enc") @db.Text
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Organization {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(64)
  ownerUserId String    @map("owner_user_id") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner      User        @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  workspaces Workspace[]

  @@index([ownerUserId])
  @@map("organizations")
}

model Workspace {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String          @db.VarChar(255)
  slug           String          @db.VarChar(64)
  description    String?         @db.Text
  status         WorkspaceStatus @default(active)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members            WorkspaceMember[]
  invitations        Invitation[]
  outboxEvents       OutboxEvent[]
  inboxEvents        InboxEvent[]
  roles              Role[]
  abacPolicies       AbacPolicy[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  timelineEvents     TimelineEvent[]
  idempotencyRecords IdempotencyRecord[]
  workflows          Workflow[]
  workflowVersions   WorkflowVersion[]
  searchDocuments    SearchDocument[]
  tags               Tag[]
  executions         WorkflowExecution[]
  executionSteps     ExecutionStep[]
  schedules          Schedule[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  status      MemberStatus @default(active)
  /// Denormalized primary role slug (synced from Role.slug) for M1 compat
  role        String       @default("owner") @db.VarChar(64)
  roleId      String?      @map("role_id") @db.Uuid
  joinedAt    DateTime     @default(now()) @map("joined_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryRole Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)
  memberRoles MemberRole[]

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([roleId])
  @@map("workspace_members")
}

model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  email       String           @db.VarChar(320)
  tokenHash   String           @unique @map("token_hash") @db.VarChar(128)
  status      InvitationStatus @default(pending)
  role        String           @default("viewer") @db.VarChar(64)
  invitedById String           @map("invited_by_id") @db.Uuid
  expiresAt   DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt  DateTime?        @map("accepted_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitationInviter", fields: [invitedById], references: [id])

  @@index([workspaceId, email])
  @@index([status])
  @@map("invitations")
}

model OutboxEvent {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String?   @map("workspace_id") @db.Uuid
  aggregateType   String    @map("aggregate_type") @db.VarChar(64)
  aggregateId     String    @map("aggregate_id") @db.Uuid
  eventType       String    @map("event_type") @db.VarChar(128)
  payload         Json
  metadata        Json?
  occurredAt      DateTime  @map("occurred_at") @db.Timestamptz(6)
  publishedAt     DateTime? @map("published_at") @db.Timestamptz(6)
  publishAttempts Int       @default(0) @map("publish_attempts")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([publishedAt, createdAt])
  @@index([eventType])
  @@map("outbox_events")
}

model InboxEvent {
  id          String   @id @default(uuid()) @db.Uuid
  consumerId  String   @map("consumer_id") @db.VarChar(128)
  eventId     String   @map("event_id") @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  processedAt DateTime @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([consumerId, eventId])
  @@map("inbox_events")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(128)
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  /// Null for system roles (seeded once; app must enforce single slug)
  workspaceId String?   @map("workspace_id") @db.Uuid
  name        String    @db.VarChar(128)
  slug        String    @db.VarChar(64)
  description String?   @db.Text
  isSystem    Boolean   @default(false) @map("is_system")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace       Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  memberRoles     MemberRole[]
  members         WorkspaceMember[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([isSystem])
  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model MemberRole {
  id       String @id @default(uuid()) @db.Uuid
  memberId String @map("member_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid

  member WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
  @@index([roleId])
  @@map("member_roles")
}

model AbacPolicy {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  name        String     @db.VarChar(255)
  effect      AbacEffect
  permissions Json
  conditions  Json
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("abac_policies")
}

model ApiKey {
  id              String       @id @default(uuid()) @db.Uuid
  workspaceId     String       @map("workspace_id") @db.Uuid
  name            String       @db.VarChar(255)
  keyPrefix       String       @map("key_prefix") @db.VarChar(16)
  keyHash         String       @unique @map("key_hash") @db.VarChar(128)
  scopes          Json
  status          ApiKeyStatus @default(active)
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  expiresAt       DateTime?    @map("expires_at") @db.Timestamptz(6)
  lastUsedAt      DateTime?    @map("last_used_at") @db.Timestamptz(6)
  revokedAt       DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User       @relation("ApiKeyCreator", fields: [createdByUserId], references: [id])
  auditLogs AuditLog[] @relation("AuditLogApiKey")

  @@index([workspaceId])
  @@index([createdByUserId])
  @@index([status])
  @@map("api_keys")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String?  @map("workspace_id") @db.Uuid
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  actorApiKeyId String?  @map("actor_api_key_id") @db.Uuid
  action        String   @db.VarChar(128)
  resourceType  String   @map("resource_type") @db.VarChar(64)
  resourceId    String?  @map("resource_id") @db.Uuid
  before        Json?
  after         Json?
  ip            String?  @db.VarChar(64)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  correlationId String?  @map("correlation_id") @db.VarChar(128)
  reason        String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actorUser   User?      @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorApiKey ApiKey?    @relation("AuditLogApiKey", fields: [actorApiKeyId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorUserId])
  @@index([action])
  @@map("audit_logs")
}

model TimelineEvent {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  eventType    String   @map("event_type") @db.VarChar(128)
  title        String   @db.VarChar(255)
  summary      String?  @db.Text
  resourceType String?  @map("resource_type") @db.VarChar(64)
  resourceId   String?  @map("resource_id") @db.Uuid
  metadata     Json?
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser User?     @relation("TimelineEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@map("timeline_events")
}

model IdempotencyRecord {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String?  @map("workspace_id") @db.Uuid
  actorKey     String   @map("actor_key") @db.VarChar(128)
  key          String   @db.VarChar(128)
  method       String   @db.VarChar(16)
  path         String   @db.VarChar(512)
  requestHash  String?  @map("request_hash") @db.VarChar(128)
  statusCode   Int      @map("status_code")
  responseBody Json?    @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([actorKey, key])
  @@index([workspaceId])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model Workflow {
  id                   String         @id @default(uuid()) @db.Uuid
  workspaceId          String         @map("workspace_id") @db.Uuid
  name                 String         @db.VarChar(255)
  description          String?        @db.Text
  status               WorkflowStatus @default(draft)
  isTemplate           Boolean        @default(false) @map("is_template")
  /// Optimistic lock counter
  version              Int            @default(1)
  publishedVersionId   String?        @map("published_version_id") @db.Uuid
  createdByUserId      String         @map("created_by_user_id") @db.Uuid
  deletedAt            DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User              @relation("WorkflowCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  draft            WorkflowDraft?
  versions         WorkflowVersion[] @relation("WorkflowVersions")
  publishedVersion WorkflowVersion?  @relation("WorkflowPublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  tags             WorkflowTag[]

  @@index([workspaceId, deletedAt, updatedAt(sort: Desc)])
  @@index([workspaceId, status])
  @@map("workflows")
}

model WorkflowDraft {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @unique @map("workflow_id") @db.Uuid
  graphJson  Json     @map("graph_json")
  savedAt    DateTime @default(now()) @map("saved_at") @db.Timestamptz(6)
  savedById  String?  @map("saved_by_id") @db.Uuid

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  savedBy  User?    @relation("WorkflowDraftSaver", fields: [savedById], references: [id], onDelete: SetNull)

  @@map("workflow_drafts")
}

model WorkflowVersion {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  workflowId    String   @map("workflow_id") @db.Uuid
  versionNumber Int      @map("version_number")
  changelog     String?  @db.Text
  snapshotHash  String   @map("snapshot_hash") @db.VarChar(64)
  graphJson     Json     @map("graph_json")
  publishedById String   @map("published_by_id") @db.Uuid
  publishedAt   DateTime @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace              Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow               Workflow             @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  publishedBy            User                 @relation("WorkflowVersionPublisher", fields: [publishedById], references: [id], onDelete: Restrict)
  currentlyPublishedFor  Workflow[]           @relation("WorkflowPublishedVersion")
  nodes                  WorkflowNode[]
  connections            WorkflowConnection[]
  variables              WorkflowVariable[]
  executions             WorkflowExecution[]
  schedules              Schedule[]

  @@unique([workflowId, versionNumber])
  @@index([workspaceId, workflowId])
  @@map("workflow_versions")
}

model WorkflowNode {
  id        String           @id @default(uuid()) @db.Uuid
  versionId String           @map("version_id") @db.Uuid
  nodeKey   String           @map("node_key") @db.VarChar(128)
  nodeType  WorkflowNodeType @map("node_type")
  typeKey   String           @map("type_key") @db.VarChar(128)
  label     String           @db.VarChar(255)
  config    Json             @default("{}")
  position  Json             @default("{}")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  version            WorkflowVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)
  outgoingConnections WorkflowConnection[] @relation("ConnectionSource")
  incomingConnections WorkflowConnection[] @relation("ConnectionTarget")
  executionSteps     ExecutionStep[]

  @@unique([versionId, nodeKey])
  @@index([versionId])
  @@map("workflow_nodes")
}

model WorkflowConnection {
  id           String   @id @default(uuid()) @db.Uuid
  versionId    String   @map("version_id") @db.Uuid
  sourceNodeId String   @map("source_node_id") @db.Uuid
  sourcePort   String   @default("out") @map("source_port") @db.VarChar(64)
  targetNodeId String   @map("target_node_id") @db.Uuid
  targetPort   String   @default("in") @map("target_port") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  version    WorkflowVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  sourceNode WorkflowNode    @relation("ConnectionSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode WorkflowNode    @relation("ConnectionTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("workflow_connections")
}

model WorkflowVariable {
  id          String  @id @default(uuid()) @db.Uuid
  versionId   String  @map("version_id") @db.Uuid
  key         String  @db.VarChar(128)
  value       String  @db.Text
  description String? @db.Text

  version WorkflowVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, key])
  @@map("workflow_variables")
}

model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String   @db.VarChar(64)
  color       String?  @db.VarChar(16)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflows WorkflowTag[]

  @@unique([workspaceId, name])
  @@map("tags")
}

model WorkflowTag {
  workflowId String @map("workflow_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workflowId, tagId])
  @@map("workflow_tags")
}

/// Full-text search projection (M3); refined in M6
model SearchDocument {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(64)
  entityId    String   @map("entity_id") @db.Uuid
  title       String   @db.VarChar(512)
  body        String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, entityType, entityId])
  @@index([workspaceId, entityType])
  @@map("search_documents")
}

model WorkflowExecution {
  id                String               @id @default(uuid()) @db.Uuid
  workspaceId       String               @map("workspace_id") @db.Uuid
  workflowVersionId String               @map("workflow_version_id") @db.Uuid
  workflowId        String               @map("workflow_id") @db.Uuid
  status            ExecutionStatus      @default(queued)
  triggerType       ExecutionTriggerType @map("trigger_type")
  triggerPayload    Json?                @map("trigger_payload")
  idempotencyKey    String?              @map("idempotency_key") @db.VarChar(255)
  sandbox           Boolean              @default(false)
  errorCode         String?              @map("error_code") @db.VarChar(64)
  errorMessage      String?              @map("error_message") @db.Text
  startedByUserId   String?              @map("started_by_user_id") @db.Uuid
  replayOfId        String?              @map("replay_of_id") @db.Uuid
  startedAt         DateTime?            @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?            @map("completed_at") @db.Timestamptz(6)
  checkpoint        Json?
  version           Int                  @default(1)
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion  @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  startedBy       User?            @relation("ExecutionStarter", fields: [startedByUserId], references: [id], onDelete: SetNull)
  replayOf        WorkflowExecution?  @relation("ExecutionReplay", fields: [replayOfId], references: [id], onDelete: SetNull)
  replays         WorkflowExecution[] @relation("ExecutionReplay")
  steps           ExecutionStep[]
  logs            ExecutionLog[]
  metrics         ExecutionMetric[]

  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, workflowVersionId])
  @@index([workflowId])
  @@unique([workspaceId, idempotencyKey])
  @@map("workflow_executions")
}

model ExecutionStep {
  id            String              @id @default(uuid()) @db.Uuid
  workspaceId   String              @map("workspace_id") @db.Uuid
  executionId   String              @map("execution_id") @db.Uuid
  nodeId        String?             @map("node_id") @db.Uuid
  nodeKey       String              @map("node_key") @db.VarChar(128)
  sequenceNumber Int                @map("sequence_number")
  status        ExecutionStepStatus @default(pending)
  inputPayload  Json?               @map("input_payload")
  outputPayload Json?               @map("output_payload")
  errorCode     String?             @map("error_code") @db.VarChar(64)
  errorMessage  String?             @map("error_message") @db.Text
  attemptNumber Int                 @default(1) @map("attempt_number")
  startedAt     DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime?           @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  node      WorkflowNode?     @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  logs      ExecutionLog[]

  @@unique([executionId, sequenceNumber, attemptNumber])
  @@index([executionId, status])
  @@map("execution_steps")
}

model ExecutionLog {
  id          String   @id @default(uuid()) @db.Uuid
  executionId String   @map("execution_id") @db.Uuid
  stepId      String?  @map("step_id") @db.Uuid
  level       String   @db.VarChar(16)
  message     String   @db.Text
  context     Json?
  loggedAt    DateTime @default(now()) @map("logged_at") @db.Timestamptz(6)

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      ExecutionStep?    @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([executionId, loggedAt])
  @@map("execution_logs")
}

model ExecutionMetric {
  id          String   @id @default(uuid()) @db.Uuid
  executionId String   @map("execution_id") @db.Uuid
  metricName  String   @map("metric_name") @db.VarChar(128)
  value       Float
  unit        String?  @db.VarChar(32)
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("execution_metrics")
}

model Schedule {
  id                String         @id @default(uuid()) @db.Uuid
  workspaceId       String         @map("workspace_id") @db.Uuid
  workflowId        String         @map("workflow_id") @db.Uuid
  workflowVersionId String         @map("workflow_version_id") @db.Uuid
  name              String         @db.VarChar(255)
  cronExpression    String         @map("cron_expression") @db.VarChar(128)
  timezone          String         @default("UTC") @db.VarChar(64)
  status            ScheduleStatus @default(active)
  nextRunAt         DateTime?      @map("next_run_at") @db.Timestamptz(6)
  lastRunAt         DateTime?      @map("last_run_at") @db.Timestamptz(6)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
  @@index([workspaceId])
  @@map("schedules")
}
