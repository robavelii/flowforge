{
  "uid": "flowforge-workflow-execution",
  "title": "FlowForge Workflow Execution",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Execution Queue Jobs",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flowforge_worker_queue_jobs_total{queue=\"workflow.execution\"}[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Execution Queue Depth",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(flowforge_worker_queue_depth{queue=\"workflow.execution\"}) by (state)",
          "legendFormat": "{{state}}"
        }
      ]
    }
  ]
}
